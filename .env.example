# mah-stack-starter — environment variables
#
# Copy this file to `.env` for LOCAL development:
#   cp .env.example .env
#
# For Cloudflare Pages: set these in the Pages dashboard
# (Project → Settings → Environment variables). The starter index.html
# expects them to be substituted into __SUPABASE_URL__ and __SUPABASE_ANON_KEY__
# at build time, OR for you to replace those tokens manually before deploying.

# --- Supabase ---
# Project URL — same shape as: https://abcdefghijklmnopqrst.supabase.co
SUPABASE_URL=

# Public anon key — long JWT starting with `eyJ`. Safe to expose; protected by RLS.
SUPABASE_ANON_KEY=

# Service-role key — bypasses RLS. NEVER commit this. Only used server-side
# (e.g. inside Edge Functions where Cloudflare/Supabase manages it as a secret).
# Leave this commented out for the static-only Tier 1 setup.
# SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: AI features ---
# OpenRouter — one API key, every model. Used only by Edge Functions / server-side.
# Never put this in browser code.
# OPENROUTER_API_KEY=

# --- Optional: Email (for production magic-link delivery) ---
# Until you set this up, Supabase's built-in mailer (rate-limited to ~3/hr) sends.
# When you switch SMTP providers, set these in Supabase Auth → URL Configuration → SMTP.
# AWS_SES_REGION=ap-southeast-2
# AWS_SES_ACCESS_KEY_ID=
# AWS_SES_SECRET_ACCESS_KEY=

# --- Optional: site config ---
SITE_NAME=My First Stack
SITE_DESCRIPTION=A small site I built using the mah-stack-starter template.
